NODE_ENV=production
API_PORT=4000
CLIENT_ORIGIN=http://localhost:8080
VITE_API_URL=/api/v1

MONGO_ROOT_USERNAME=medvault
MONGO_ROOT_PASSWORD=change_this_mongo_root_password
MONGO_DATABASE=medvault
MONGODB_URI=mongodb://medvault:change_this_mongo_root_password@mongodb:27017/medvault?authSource=admin

REDIS_URL=redis://redis:6379

ACCESS_TOKEN_SECRET=replace_with_a_strong_64_character_access_secret
REFRESH_TOKEN_SECRET=replace_with_a_strong_64_character_refresh_secret
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000
JWT_ISSUER=medvault-api
JWT_AUDIENCE=medvault-web
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=lax

STORAGE_PROVIDER=local
LOCAL_UPLOAD_DIR=/app/uploads
MAX_DOCUMENT_UPLOAD_BYTES=10485760

EMAIL_QUEUE_NAME=medvault-email

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="MedVault <no-reply@medvault.local>"